    "GET /rules": {
      "description": "Fetch fee rules with optional state/case-type filters",
      "queryParams": {
        "stateId": { "type": "integer", "optional": true, "description": "Filter by state ID" },
        "caseTypeId": { "type": "integer", "optional": true, "description": "Filter by case type ID" }
      },
      "response": {
        "success": true,
        "total": 1,
        "data": [
          {
            "id": 1,
            "stateId": 1,
            "stateName": "Delhi",
            "caseTypeId": 1,
            "caseTypeName": "Money Recovery Suit",
            "feeType": "slab",
            "minimumFee": 100,
            "maximumFee": 150000,
            "slabs": [
              { "slabStart": 0, "slabEnd": 50000, "percentageRate": 2.0, "fixedComponent": 0, "description": "2% on first ₹50,000" },
              { "slabStart": 50000, "slabEnd": 100000, "percentageRate": 3.0, "fixedComponent": 0, "description": "3% on ₹50,001 – ₹1,00,000" },
